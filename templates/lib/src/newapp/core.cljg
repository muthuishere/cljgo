;; newapp.core — generated by `cljgo new`. This file is YOURS.
;;
;; A library is plain namespaces of plain fns. Nothing here runs at load
;; time: requiring this namespace produces values, never events — which
;; is what lets a test (or a REPL, or somebody else's app) pull it in
;; without starting a world.
(ns newapp.core)

(defn greet
  "Return a greeting for `name`."
  [name]
  (str "Hello, " name "!"))
