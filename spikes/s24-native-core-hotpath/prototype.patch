+	// reduce : the seq-walking fold, native like the other hot builtins.
+	// 2-arity seeds from the first element and calls (f) on an empty coll;
+	// both arities honor the `reduced` short-circuit box.
+	// oracle: (reduce + 0 (range 1 11)) => 55; (reduce + (range 1 11)) => 55.
+	def("reduce", func(args ...any) any {
+		var f, acc any
+		var s lang.ISeq
+		switch len(args) {
+		case 2:
+			f = args[0]
+			s = lang.Seq(args[1])
+			if lang.IsNil(s) {
+				return lang.Apply(f, nil)
+			}
+			acc = s.First()
+			s = s.Next()
+		case 3:
+			f = args[0]
+			acc = args[1]
+			s = lang.Seq(args[2])
+		default:
+			panic(fmt.Errorf("wrong number of args (%d) passed to: reduce", len(args)))
+		}
+		for !lang.IsNil(s) {
+			acc = lang.Apply2(f, acc, s.First())
+			if r, ok := acc.(*lang.Reduced); ok {
+				return r.Deref()
+			}
+			s = s.Next()
+		}
+		return acc
+	})
