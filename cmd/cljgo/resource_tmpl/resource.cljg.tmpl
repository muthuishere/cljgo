;; app.{{.Plural}} — a CRUD resource generated by
;; `{{.Command}}`
;;
;; Handlers are JSON + authenticated (ADR 0069). The MODEL section is the
;; only place that touches bri.core.data (ADR 0072); `ds` is the datasource
;; (@app.db/ds) and every query is parametrized. This file is YOURS — edit
;; it freely; `cljgo generate resource` never rewrites an existing one.
(ns {{.Ns}}
  (:require [bri.web.http :as http :refer [GET POST PUT DELETE]]
            [bri.core.security :as auth]
            [bri.core.data :as db]
            [app.db :as adb]))

;; --- coercion: JSON body -> typed column values ---------------------------
{{if .NeedsLong}}(defn ->long [v]
  (cond (number? v) (long v) (string? v) (parse-long v) :else v))
{{end}}{{if .NeedsBool}}(defn ->bool [v]
  (cond (boolean? v) v (string? v) (= "true" v) (number? v) (not (zero? v)) :else (boolean v)))
{{end}}(defn coerce
  "Pick this resource's fields out of an incoming JSON body, typed."
  [m]
  {{"{"}}{{range .Fields}}{{.Keyword}} {{.CoerceExpr}}
   {{end}}})

;; --- model: parametrized bri.core.data calls (ADR 0072) ------------------------
;; query -> vector of keyword-keyed maps; one -> a single map or nil.
(defn all      [ds]        (db/query   ds "SELECT * FROM {{.Table}} ORDER BY id DESC"))
(defn fetch    [ds id]     (db/one     ds "SELECT * FROM {{.Table}} WHERE id = ?" id))
(defn create!  [ds row]    (db/insert! ds {{.TableKw}} row))
(defn modify!  [ds id row] (db/exec!   ds "UPDATE {{.Table}} SET {{.SetClause}} WHERE id = ?" {{.SetArgs}} id))
(defn destroy! [ds id]     (db/exec!   ds "DELETE FROM {{.Table}} WHERE id = ?" id))

;; --- handlers: Ring request -> response; a map body auto-encodes as JSON --
(defn index [_req]
  (http/ok {{"{"}}{{.CollKw}} (all @adb/ds)}))

(defn show [req]
  (let [id (http/param! req :id :int)]
    (if-let [row (fetch @adb/ds id)]
      (http/ok row)
      (http/not-found {:error "{{.Singular}} not found"}))))

(defn create [req]
  (let [row (coerce (:json req))]
    (http/created (create! @adb/ds row))))

(defn update-one [req]
  (let [id  (http/param! req :id :int)
        row (coerce (:json req))]
    (modify! @adb/ds id row)
    (http/ok (fetch @adb/ds id))))

(defn delete-one [req]
  (let [id (http/param! req :id :int)]
    (destroy! @adb/ds id)
    (http/no-content)))

;; --- routes: spliced into app.main by `cljgo generate resource` -----------
;; All authenticated; destroy is admin-only. Named routes power reverse
;; routing: (http/path-for {{.MemberKw}} {:id 5}).
(def routes
  (http/routes
    (GET    "{{.RouteBase}}"      {:name {{.CollKw}}}   (auth/logged-in-only) #'index)
    (GET    "{{.RouteBase}}/{id}" {:name {{.MemberKw}}} (auth/logged-in-only) #'show)
    (POST   "{{.RouteBase}}"      (auth/logged-in-only) #'create)
    (PUT    "{{.RouteBase}}/{id}" (auth/logged-in-only) #'update-one)
    (DELETE "{{.RouteBase}}/{id}" (auth/admin-only)     #'delete-one)))
