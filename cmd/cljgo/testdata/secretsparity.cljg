;; secretsparity.cljg — bri.core.secrets dual-mode parity fixture (ADR 0086).
;; Drives the masked-secret surface over the env provider and prints a
;; deterministic transcript. Run interpreted (`cljgo run`) and AOT-compiled
;; (`cljgo build`), the output must be byte-identical — and it proves a
;; bri.core.secrets app LINKS opt-in and compiles CGO_ENABLED=0. $BRI_PARITY_SECRET
;; is injected by the test as "alpha" (5 chars).
(require '[bri.core.secrets :as secrets])

(println "masked"   (:masked (secrets/get "env://BRI_PARITY_SECRET")))
(println "revealed" (secrets/reveal (secrets/get "env://BRI_PARITY_SECRET")))
(println "chain"    (secrets/reveal (secrets/get ["env://BRI_MISS" "env://BRI_PARITY_SECRET"])))
(println "miss"     (pr-str (secrets/get "env://BRI_MISS")))
(println "secret?"  (secrets/secret? (secrets/get "env://BRI_PARITY_SECRET")))
