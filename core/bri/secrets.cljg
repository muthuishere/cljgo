;; bri.core.secrets — the pluggable secret store (ADR 0086, realizing ADR 0060
;; / spike S39). A backend is chosen purely by the URI scheme in the caller's
;; string — nothing hardcodes a provider:
;;
;;   (require '[bri.core.secrets :as secrets])
;;   (secrets/get "env://DATABASE_URL")               ; => #masked secret, or nil
;;   (secrets/get "keychain://myapp/db-password")     ; OS keychain (pure-Go)
;;   (secrets/get ["keychain://myapp/db" "env://DB"]) ; fallback: first hit wins
;;   (secrets/reveal (secrets/get "env://DB"))        ; the ONE explicit unmask
;;   (secrets/set "keychain://myapp/token" api-key)   ; keychain is writable
;;
;; HYGIENE (ADR 0086 / CLAUDE.md absolute rule): `get` returns a MASKED secret
;; object whose printed form shows only `len=N ***…xy` — the raw value lives in
;; the object's metadata, which pr/println do NOT print. So an accidental
;; (println secret) is safe; plaintext requires an explicit `reveal` (grep for
;; it to audit every unmask site). The chain + masking policy is portable
;; Clojure; only the scalar fetch/store are host shims (pkg/bri/secrets).
;;
;; OPT-IN (ADR 0074/0076): like bri.core.data / bri.core.telemetry, the keychain
;; client links only when an app requires this namespace. Private Go shims
;; interned before this loads: -secret-get1 -secret-set1 -secret-del1.
;;
;; Loaded as a bri namespace (ADR 0041): NO (ns …) form — fully-qualified
;; in-ns + refer first (they resolve before clojure.core is referred). `get`
;; and `set` deliberately shadow clojure.core INSIDE this namespace only
;; (callers write secrets/get), per the S39 design — so core's get/set are
;; excluded from the refer.
(clojure.core/in-ns 'bri.core.secrets)
(clojure.core/refer 'clojure.core :exclude '[get set])

;; --- the masked secret object (raw kept in metadata, never printed) ---------

(defn- mask
  "Render a value safe for any surface: never the plaintext. `len=N ***…xy`
  keeps only the last 2 chars as a disambiguator; tiny values leak neither."
  [v]
  (let [n (count v)]
    (cond
      (zero? n) "***(empty)"
      (< n 4)   (str "len=" n " ***")
      :else     (str "len=" n " ***…" (subs v (- n 2))))))

(defn secret
  "Wrap a raw string as a masked secret: the map prints as its mask only, the
  plaintext lives in metadata (pr/println don't print metadata)."
  [raw]
  (with-meta {:bri.core.secrets/secret true :masked (mask raw)}
             {:bri.core.secrets/raw raw}))

(defn secret?
  "Is x a masked secret object?"
  [x]
  (boolean (and (map? x) (:bri.core.secrets/secret x))))

(defn reveal
  "Return a secret's plaintext — THE explicit, auditable unmask seam. Grep for
  `reveal` to find every place a value is unwrapped. A bare string passes
  through, so callers can `(reveal maybe-secret)` uniformly."
  [s]
  (if (secret? s) (:bri.core.secrets/raw (meta s)) s))

;; --- get / set / delete (chain policy is portable, per ADR 0086) ------------

(defn- as-uris [uri-or-uris]
  (if (sequential? uri-or-uris) (vec uri-or-uris) [uri-or-uris]))

(defn get
  "Fetch a secret from the first backend that has it. `uri-or-uris` is one URI
  (env://KEY or keychain://service/account) or a vector tried left→right —
  first hit wins; a real backend failure aborts (never falls through to a
  weaker source). Optional `key` overrides an account in a keychain URI.
  Returns a MASKED secret (use `reveal` for the plaintext), or nil if no
  backend has it."
  ([uri-or-uris] (get uri-or-uris ""))
  ([uri-or-uris key]
   (loop [uris (as-uris uri-or-uris)]
     (when-let [u (first uris)]
       (if-let [raw (-secret-get1 u (or key ""))]
         (secret raw)
         (recur (rest uris)))))))

(defn set
  "Store a raw value in a writable backend (keychain://service/account); env://
  is read-only. `value` may be a raw string or a secret (revealed at the
  boundary). Returns nil."
  ([uri value] (set uri "" value))
  ([uri key value] (-secret-set1 uri (or key "") (reveal value)) nil))

(defn delete
  "Remove a secret from a writable backend. Returns nil."
  ([uri] (delete uri ""))
  ([uri key] (-secret-del1 uri (or key "")) nil))
