;; bri.core.secrets — the secret store (ADR 0086, realizing ADR 0060 / spike
;; S39). Bun.secrets parity: the DEFAULT backend is the OS keychain by
;; (service, name), so you save/read an API key without ever naming a backend —
;; it goes to "whatever keychain the OS has" (macOS Keychain, Linux Secret
;; Service, Windows Credential Manager), pure-Go via go-keyring:
;;
;;   (require '[bri.core.secrets :as secrets])
;;   (secrets/set "my-app" "api-key" "sk-live-…")     ; → OS keychain
;;   (secrets/get "my-app" "api-key")                 ; => masked secret, or nil
;;   (secrets/reveal (secrets/get "my-app" "api-key")); the ONE explicit unmask
;;   (secrets/delete "my-app" "api-key")
;;   ;; map form, mirroring Bun.secrets.set({service, name, value}):
;;   (secrets/set {:service "my-app" :name "api-key" :value "sk-live-…"})
;;
;; Advanced (the S39 pluggable layer): a URI scheme selects a backend, and a
;; vector is a left→right fallback chain — distinguished by the "://":
;;   (secrets/get "env://DATABASE_URL")               ; env var
;;   (secrets/get ["keychain://my-app/db" "env://DB"]); fallback: first hit wins
;;
;; HYGIENE (ADR 0086 / CLAUDE.md absolute rule): `get` returns a MASKED secret
;; object whose printed form shows only `len=N ***…xy` — the raw value lives in
;; the object's metadata, which pr/println do NOT print. So an accidental
;; (println secret) is safe; plaintext requires an explicit `reveal` (grep for
;; it to audit every unmask site). The chain + masking policy is portable
;; Clojure; only the scalar fetch/store are host shims (pkg/bri/secrets).
;;
;; OPT-IN (ADR 0074/0076): like bri.core.data / bri.core.telemetry, the keychain
;; client links only when an app requires this namespace. Private Go shims
;; interned before this loads: -secret-get1 -secret-set1 -secret-del1.
;;
;; Loaded as a bri namespace (ADR 0041): NO (ns …) form — fully-qualified
;; in-ns + refer first (they resolve before clojure.core is referred). `get`
;; and `set` deliberately shadow clojure.core INSIDE this namespace only
;; (callers write secrets/get), per the S39 design — so core's get/set are
;; excluded from the refer.
(clojure.core/in-ns 'bri.core.secrets)
(clojure.core/refer 'clojure.core :exclude '[get set])
(require '[clojure.string :as str])

;; --- the masked secret object (raw kept in metadata, never printed) ---------

(defn- mask
  "Render a value safe for any surface: never the plaintext. `len=N ***…xy`
  keeps only the last 2 chars as a disambiguator; tiny values leak neither."
  [v]
  (let [n (count v)]
    (cond
      (zero? n) "***(empty)"
      (< n 4)   (str "len=" n " ***")
      :else     (str "len=" n " ***…" (subs v (- n 2))))))

(defn secret
  "Wrap a raw string as a masked secret: the map prints as its mask only, the
  plaintext lives in metadata (pr/println don't print metadata)."
  [raw]
  (with-meta {:bri.core.secrets/secret true :masked (mask raw)}
             {:bri.core.secrets/raw raw}))

(defn secret?
  "Is x a masked secret object?"
  [x]
  (boolean (and (map? x) (:bri.core.secrets/secret x))))

(defn reveal
  "Return a secret's plaintext — THE explicit, auditable unmask seam. Grep for
  `reveal` to find every place a value is unwrapped. A bare string passes
  through, so callers can `(reveal maybe-secret)` uniformly."
  [s]
  (if (secret? s) (:bri.core.secrets/raw (meta s)) s))

;; --- get / set / delete: the Bun.secrets front door + the scheme chain ------
;; The DEFAULT is the OS keychain by (service, name) — exactly like
;; `Bun.secrets.get({service, name})` — so you never write a URI to save an API
;; key to "whatever keychain the OS has". The URI/scheme layer (env://, a
;; fallback vector) is the advanced path, distinguished by the "://" in the
;; string.

(defn- uri-string? [x] (and (string? x) (str/includes? x "://")))

(defn- kc-get [service account]
  (when-let [raw (-keychain-get (str service) (str account))]
    (secret raw)))

(defn- chain-get [uris key]
  (loop [us uris]
    (when-let [u (first us)]
      (if-let [raw (-secret-get1 u (or key ""))]
        (secret raw)
        (recur (rest us))))))

(defn get
  "Fetch a secret; MASKED (use `reveal` for the plaintext), or nil if absent.

  Bun.secrets front door (the OS keychain — Keychain / Secret Service /
  Credential Manager):
    (get \"my-app\" \"api-key\")
    (get {:service \"my-app\" :name \"api-key\"})

  Advanced (scheme URIs): a single URI, or a vector tried left→right (first hit
  wins; a real backend failure aborts, never falling through to a weaker
  source):
    (get \"env://DATABASE_URL\")
    (get [\"keychain://my-app/db\" \"env://DATABASE_URL\"])"
  ([spec]
   (cond
     (map? spec)        (kc-get (:service spec) (:name spec))
     (sequential? spec) (chain-get (vec spec) "")
     (uri-string? spec) (chain-get [spec] "")
     :else (throw (ex-info "secrets/get: pass (service name), {:service :name}, or a URI"
                           {:bri/error :bri.core.secrets/bad-arg :got spec}))))
  ([service-or-uri name-or-key]
   (if (uri-string? service-or-uri)
     (chain-get [service-or-uri] (or name-or-key ""))
     (kc-get service-or-uri name-or-key))))

(defn set
  "Store a secret. `value` may be a raw string or a secret (revealed at the
  boundary). Returns nil.

  Bun.secrets front door (writes the OS keychain):
    (set \"my-app\" \"api-key\" \"sk-live-…\")
    (set {:service \"my-app\" :name \"api-key\" :value \"sk-live-…\"})

  Advanced: (set \"keychain://svc/acct\" value) — env:// is read-only."
  ([spec]
   (if (map? spec)
     (do (-keychain-set (str (:service spec)) (str (:name spec)) (reveal (:value spec))) nil)
     (throw (ex-info "secrets/set: pass {:service :name :value}, or (service name value)"
                     {:bri/error :bri.core.secrets/bad-arg :got spec}))))
  ([uri value]
   (-secret-set1 uri "" (reveal value)) nil)
  ([service-or-uri name value]
   (if (uri-string? service-or-uri)
     (-secret-set1 service-or-uri (or name "") (reveal value))
     (-keychain-set (str service-or-uri) (str name) (reveal value)))
   nil))

(defn delete
  "Remove a secret. Deleting an absent key is a no-op. Returns nil.

  Bun.secrets front door: (delete \"my-app\" \"api-key\") or
  (delete {:service \"my-app\" :name \"api-key\"}).
  Advanced: (delete \"keychain://svc/acct\")."
  ([spec]
   (cond
     (map? spec)        (-keychain-del (str (:service spec)) (str (:name spec)))
     (uri-string? spec) (-secret-del1 spec "")
     :else (throw (ex-info "secrets/delete: pass (service name), {:service :name}, or a URI"
                           {:bri/error :bri.core.secrets/bad-arg :got spec})))
   nil)
  ([service-or-uri name]
   (if (uri-string? service-or-uri)
     (-secret-del1 service-or-uri (or name ""))
     (-keychain-del (str service-or-uri) (str name)))
   nil))
