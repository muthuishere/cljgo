;; test.cljg — cljgo's clojure.test bootstrap (interpreted slice of
;; ADR 0012 / openspec testing-first-class, task 1.1). Loaded at startup
;; into the clojure.test namespace by pkg/eval (loadClojureTest), AFTER
;; clojure.core is up. The .cljg extension follows ADR 0017.
;;
;; Behavior is oracle-verified against JVM Clojure 1.12.5 clojure.test:
;;   (run-tests) over {2 pass-assertions, 1 fail, 1 error, 1 testing-pass}
;;   => {:test 4, :pass 3, :fail 1, :error 1, :type :summary}
;; where :test counts deftests run and pass+fail+error counts assertions
;; ("Ran N tests containing M assertions.").
;;
;; Since try/catch/throw + ex-info/ex-message landed in the evaluator, every
;; assertion is guarded by a REAL (try ... (catch Throwable ...)) — the same
;; shape as JVM clojure.test's try-expr — so a throwing body reports :error
;; and the run continues. (is (thrown? Class body)) and
;; (is (thrown-with-msg? Class #"re" body)) are now supported via real
;; try/catch; class matching follows the evaluator's CatchMatches (design/03
;; §6): Throwable/Exception/RuntimeException match any thrown value,
;; ExceptionInfo matches an ex-info. thrown-with-msg? matches the message
;; with a real regex via the -re-find? host seam (cljgo has no re-find yet).
;;
;; use-fixtures (:each / :once) landed (ADR 0022 batch/harness-misc): a
;; per-namespace fixture function stored in ns metadata under
;; ::each-fixtures / ::once-fixtures (real clojure.test's add-ns-meta shape),
;; composed via join-fixtures/compose-fixtures and applied by test-vars —
;; oracle: clojure.test source (use-fixtures/join-fixtures/compose-fixtures/
;; default-fixture/test-vars), verified with the `clojure` CLI.
;;
;; DEVIATIONS from JVM clojure.test (documented, remaining slice, task 1.2):
;;   * *test-out* / per-ns "Testing <ns>" banner / test-ns-hook are not
;;     in this slice.

;; The loader (pkg/eval loadClojureTest) already binds *ns* to a fresh
;; clojure.test; these two forms make it explicit and refer clojure.core so
;; the rest of the file resolves unqualified core names. Both are qualified
;; because clojure.test has nothing referred until the refer runs.
(clojure.core/in-ns 'clojure.test)
(clojure.core/refer 'clojure.core)

;; --- dynamic state (clojure.test shape) -----------------------------

;; *report-counters* is an atom holding {:test :pass :fail :error} while a
;; run is in progress, nil otherwise (bare (test-var) calls no-op counters).
(def ^:dynamic *report-counters* nil)
;; the vars whose test bodies are currently executing (innermost first).
(def ^:dynamic *testing-vars* nil)
;; the (testing "...") context strings currently in scope (innermost first).
(def ^:dynamic *testing-contexts* nil)

(def initial-report-counters {:test 0 :pass 0 :fail 0 :error 0})

;; --- counters + reporting -------------------------------------------

(defn inc-report-counter [k]
  (when *report-counters*
    (swap! *report-counters*
           (fn [m] (assoc m k (inc (get m k 0)))))))

(defn testing-vars-str []
  (if (seq *testing-vars*)
    (pr-str (first *testing-vars*))
    ""))

(defn testing-contexts-str []
  (loop [cs *testing-contexts* s ""]
    (if (seq cs)
      (recur (next cs) (str (first cs) " " s))
      s)))

;; do-report tallies every assertion by :type and prints failures/errors
;; showing the failing form (:expected) and the observed value (:actual).
(defn do-report [m]
  (let [t (:type m)]
    (inc-report-counter t)
    (cond
      (= t :fail)
      (do (println)
          (println "FAIL in" (testing-vars-str) (testing-contexts-str))
          (println "expected:" (pr-str (:expected m)))
          (println "  actual:" (pr-str (:actual m))))
      (= t :error)
      (do (println)
          (println "ERROR in" (testing-vars-str) (testing-contexts-str))
          (println "expected:" (pr-str (:expected m)))
          (println "  actual:" (pr-str (:actual m))))
      :else nil)))

;; --- is / testing / deftest -----------------------------------------

;; -function?: mirrors clojure.test's private `function?` — true when x is a
;; function value, or a symbol that resolves to a Var holding a function AND
;; is not a macro. `is` uses this to decide whether a seq form is a predicate
;; CALL (= a b), to be applied to its evaluated args and reported with the
;; matched values, or an arbitrary expression (let, and, or, any other macro
;; or special form) to be evaluated as-is. A true special form (let*, if,
;; do, ...) has no Var at all — resolve returns nil — and a macro's Var
;; carries :macro true, so BOTH fall through to the bare-expression case,
;; exactly like real clojure.test (oracle: clojure.test/function?, verified
;; with the `clojure` CLI). Without this gate, (is (let [x ...] ...)) would
;; wrongly try to (apply let (list bindings body)), evaluating the bindings
;; vector as plain data outside any let scope and failing to resolve its
;; binding names.
(defn ^:private -function? [x]
  (if (symbol? x)
    (let [v (resolve x)]
      (and v (clojure.core/fn? (clojure.core/deref v)) (not (:macro (meta v)))))
    (clojure.core/fn? x)))

;; `is` supports (= a b) / a plain (pred args...) call, a bare expression,
;; (thrown? Class body...) and (thrown-with-msg? Class #"re" body...) — and,
;; since the fundamentals batch below, ANY form a user teaches it about by
;; adding a method to the `assert-expr` multimethod. The structure is JVM
;; clojure.test's exactly (oracle: clojure/test.clj 1.12.5, read with
;; clojure.repl/source + the resource on the CLI classpath, 2026-07-21):
;;
;;   is        -> (try-expr msg form)
;;   try-expr  -> (try <(assert-expr msg form)> (catch Throwable ...))
;;   assert-expr — a MULTIMETHOD dispatching on the head symbol of form
;;
;; so every assertion is still wrapped in exactly one REAL
;; (try ... (catch Throwable ...)): an assertion whose body throws
;; unexpectedly reports :error and the run continues, rather than crashing
;; the process. The generated code per branch is unchanged from cljgo's
;; previous hand-rolled `is` cond — only the dispatch moved into the
;; extension point.
;;
;; NOTE on class symbols in syntax-quote: cljgo's reader keeps try/catch/throw
;; as bare specials, but a class symbol like Throwable is NOT special, so a
;; syntax-quoted `Throwable` would be namespace-qualified (=> clojure.test/
;; Throwable) and never match. The outer catch therefore forces the bare
;; symbol with ~'Throwable; the thrown?/thrown-with-msg? class is spliced
;; straight from the user's form (~klass), so it is already unqualified.

(defn assert-predicate
  "Returns generic assertion code for any functional predicate. The
  'expected' argument to 'report' will contain the original form, the
  'actual' argument will contain the form with all its sub-forms
  evaluated. If the predicate returns false, the 'actual' form will be
  wrapped in (not...)."
  [msg form]
  (let [args (rest form)
        pred (first form)]
    `(let [values# (clojure.core/list ~@args)
           result# (clojure.core/apply ~pred values#)]
       (if result#
         (do-report {:type :pass :message ~msg :expected '~form
                     :actual (clojure.core/cons '~pred values#)})
         ;; '~'not => the bare symbol `not`, so :actual prints as
         ;; (not (= 1 2)) like JVM clojure.test, not clojure.core/not.
         (do-report {:type :fail :message ~msg :expected '~form
                     :actual (clojure.core/list '~'not (clojure.core/cons '~pred values#))}))
       result#)))

(defn assert-any
  "Returns generic assertion code for any test, including macros, host
  calls, or isolated symbols."
  [msg form]
  `(let [value# ~form]
     (if value#
       (do-report {:type :pass :message ~msg :expected '~form :actual value#})
       (do-report {:type :fail :message ~msg :expected '~form :actual value#}))
     value#))

;; -assert-expr-dispatch is JVM clojure.test's assert-expr dispatch fn plus
;; ONE cljgo-specific normalization, kept from the previous `is`:
;;
;;   portability p/thrown? — the jank clojure-test-suite writes exception
;;   assertions as (is (p/thrown? body...)), a NAMESPACE-qualified thrown?
;;   (the clojure.core-test.portability hook, ADR 0022) with NO class arg,
;;   asserting the body throws *something*. On the JVM the suite's own
;;   portability.cljc registers that defmethod itself; cljgo ships its own
;;   shim (core/clojure_test_portability.cljg) instead, so the dispatch fn
;;   folds any namespaced symbol named "thrown?" (bare thrown? always
;;   carries a class) onto ::any-thrown?, whose method is below.
(defn ^:private -assert-expr-dispatch [_msg form]
  (cond
    (nil? form) :always-fail
    (seq? form)
    (let [head (first form)]
      (if (and (symbol? head) (namespace head) (= "thrown?" (name head)))
        ::any-thrown?
        head))
    :else :default))

;; assert-expr — THE extension point. (defmethod assert-expr 'my-pred
;; [msg form] ...) teaches `is` a new special form; the method is a
;; macroexpansion-time fn returning the code the assertion becomes.
(defmulti assert-expr -assert-expr-dispatch)

(defmethod assert-expr :always-fail [msg form]
  ;; nil test: always fail
  `(do-report {:type :fail :message ~msg}))

;; :default — a seq whose head is a function VALUE (not a macro, not a
;; special form) is a predicate call reported with its evaluated args;
;; anything else is an opaque expression. cljgo gates on `seq?` where the
;; JVM gates on `sequential?`: a literal vector is data here, never a
;; predicate call. Documented deviation, unchanged from the previous `is`.
(defmethod assert-expr :default [msg form]
  (if (and (seq? form) (-function? (first form)))
    (assert-predicate msg form)
    (assert-any msg form)))

(defmethod assert-expr 'thrown? [msg form]
  ;; (is (thrown? c expr)) — asserts evaluating expr throws an instance of
  ;; c. Returns the exception thrown.
  (let [klass (second form)
        body (nnext form)]
    `(try
       ~@body
       ;; body returned without throwing => the assertion fails.
       (do-report {:type :fail :message ~msg :expected '~form :actual nil})
       nil
       (catch ~klass e#
         (do-report {:type :pass :message ~msg :expected '~form :actual e#})
         e#))))

(defmethod assert-expr ::any-thrown? [msg form]
  ;; (is (p/thrown? expr)) — asserts expr throws *something*, no class arg.
  (let [body (rest form)]
    `(try
       ~@body
       (do-report {:type :fail :message ~msg :expected '~form :actual nil})
       nil
       (catch ~'Throwable e#
         (do-report {:type :pass :message ~msg :expected '~form :actual e#})
         e#))))

(defmethod assert-expr 'thrown-with-msg? [msg form]
  ;; (is (thrown-with-msg? c re expr)) — as thrown?, and the exception's
  ;; message must re-find-match re. cljgo reads the message with
  ;; ex-message and matches through the -re-find? host seam (the JVM uses
  ;; .getMessage + re-find).
  (let [klass (nth form 1)
        re (nth form 2)
        body (nthnext form 3)]
    `(try
       ~@body
       (do-report {:type :fail :message ~msg :expected '~form :actual nil})
       nil
       (catch ~klass e#
         (if (clojure.core/-re-find? ~re (ex-message e#))
           (do-report {:type :pass :message ~msg :expected '~form :actual e#})
           (do-report {:type :fail :message ~msg :expected '~form :actual e#}))
         e#))))

(defmacro try-expr
  "Used by the 'is' macro to catch unexpected exceptions.
  You don't call this."
  [msg form]
  `(try ~(assert-expr msg form)
        (catch ~'Throwable t#
          (do-report {:type :error :message ~msg :expected '~form :actual t#}))))

(defmacro is
  ([form] (list 'clojure.test/is form nil))
  ([form msg] `(try-expr ~msg ~form)))

;; `binding` is a cljgo special form (not in the reader's syntax-quote
;; special list, which knows only standard-Clojure specials), so force the
;; bare symbol with ~'binding — otherwise syntax-quote would qualify it to
;; clojure.test/binding and it would not resolve.
(defmacro testing [string & body]
  `(~'binding [*testing-contexts* (cons ~string *testing-contexts*)]
     ~@body))

;; --- are: table-driven assertions -----------------------------------

;; -take/-drop/-interleave-pairs are the tiny seq helpers `are` needs at
;; macroexpand time (cljgo core has no take/drop/interleave yet). Private to
;; clojure.test.
(defn ^:private -take [n coll]
  (loop [n n c (seq coll) acc []]
    (if (and (> n 0) c)
      (recur (dec n) (next c) (conj acc (first c)))
      (seq acc))))

(defn ^:private -drop [n coll]
  (loop [n n c (seq coll)]
    (if (and (> n 0) c)
      (recur (dec n) (next c))
      c)))

;; pair the argv symbols with one row of values => a {sym val} map, for
;; -template-subst below.
(defn ^:private -bindings-map [syms vals]
  (loop [ss (seq syms) vs (seq vals) acc {}]
    (if (and ss vs)
      (recur (next ss) (next vs) (assoc acc (first ss) (first vs)))
      acc)))

;; -template-subst: a minimal postwalk-replace (cljgo has no clojure.walk
;; yet) — recursively substitutes any subform `=` to a key of `bindings`
;; with its value, otherwise walks in. This must be TEXTUAL substitution
;; on the unevaluated form, not a runtime let-binding: `are`'s templates
;; routinely quote the arg (`(special-symbol? 'arg)`), and args are
;; sometimes bare symbols that name nothing evaluable (`&`, `case*`, a
;; special-form name) — a let would try to evaluate them and blow up
;; (clojure-test-suite special_symbol_qmark.cljc). Substituting into the
;; quote first means the final `(quote &)` is only ever read as data, the
;; same as real clojure.test's `do-template` (org.clojure/clojure
;; clojure/template.clj, Rich Hickey, EPL 1.0).
(defn ^:private -template-subst [bindings form]
  (cond
    (contains? bindings form) (get bindings form)
    (seq? form) (map (fn [x] (-template-subst bindings x)) form)
    (vector? form) (mapv (fn [x] (-template-subst bindings x)) form)
    (map? form) (into {} (map (fn [e] [(-template-subst bindings (key e))
                                        (-template-subst bindings (val e))])
                               form))
    (set? form) (into #{} (map (fn [x] (-template-subst bindings x)) form))
    :else form))

;; (are [argv] expr v0 v1 ...) expands to a (do (is expr-with-argv-textually-
;; substituted) ...), one `is` per row of `(count argv)` values — real
;; clojure.test's do-template semantics (see -template-subst above), not a
;; let-binding. Each `is` still carries its own error boundary.
(defmacro are [argv expr & args]
  (let [n (count argv)]
    (cons 'do
          (loop [as (seq args) forms []]
            (if as
              (let [row (-take n as)
                    bindings (-bindings-map argv row)]
                (recur (-drop n as)
                       (conj forms (list 'clojure.test/is (-template-subst bindings expr)))))
              forms)))))

;; deftest interns a test var: its value is a thunk that runs the test,
;; and its :test metadata holds the actual body thunk (as JVM clojure.test
;; does). run-tests discovers vars by that :test metadata.
(defmacro deftest [name & body]
  `(do
     (def ~name (fn [] (test-var (var ~name))))
     (clojure.core/alter-meta! (var ~name) clojure.core/assoc :test (fn [] ~@body))
     (var ~name)))

;; --- fixtures ---------------------------------------------------------

;; default-fixture: the empty fixture — just calls its argument.
(defn ^:private default-fixture [f] (f))

;; compose-fixtures: combine two fixture functions so f1 wraps f2.
(defn compose-fixtures [f1 f2]
  (fn [g] (f1 (fn [] (f2 g)))))

;; join-fixtures: compose a collection of fixtures, in order; always a valid
;; fixture function even for an empty collection.
(defn join-fixtures [fixtures]
  (reduce compose-fixtures default-fixture fixtures))

;; add-ns-meta: stash coll under key in the CURRENT namespace's metadata —
;; use-fixtures' storage mechanism (real clojure.test add-ns-meta).
(defn ^:private add-ns-meta [key coll]
  (clojure.core/alter-meta! *ns* clojure.core/assoc key coll))

;; use-fixtures: (use-fixtures :each f1 f2 ...) wraps every test individually;
;; (use-fixtures :once f1 f2 ...) wraps the whole namespace run once. cljgo
;; implements this as a plain function (not a multimethod — no defmulti/
;; defmethod dependency needed for two fixed dispatch values).
(defn use-fixtures [fixture-type & fixtures]
  (cond
    (= fixture-type :each) (add-ns-meta ::each-fixtures fixtures)
    (= fixture-type :once) (add-ns-meta ::once-fixtures fixtures)
    :else (throw (ex-info "First argument to use-fixtures must be :each or :once" {}))))

;; --- running --------------------------------------------------------

(defn test-var [v]
  (let [t (:test (meta v))]
    (when t
      (binding [*testing-vars* (cons v *testing-vars*)]
        (inc-report-counter :test)
        (try
          (t)
          (catch Throwable e
            (do-report {:type :error
                        :message "Uncaught exception, not in assertion."
                        :expected nil
                        :actual e})))))))

(defn report-summary [m]
  (println)
  (println "Ran" (:test m) "tests containing"
           (+ (:pass m) (:fail m) (:error m)) "assertions.")
  (println (:fail m) "failures," (:error m) "errors."))

;; test-vars: groups vars by their namespace and runs test-var on them with
;; that namespace's :once/:each fixtures applied (real clojure.test shape).
(defn test-vars [vars]
  (doseq [[ns vs] (group-by (fn [v] (:ns (meta v))) vars)]
    (let [once-fixture-fn (join-fixtures (::once-fixtures (meta ns)))
          each-fixture-fn (join-fixtures (::each-fixtures (meta ns)))]
      (once-fixture-fn
       (fn []
         (doseq [v vs]
           (when (:test (meta v))
             (each-fixture-fn (fn [] (test-var v))))))))))

(defn run-test-vars [vars]
  (binding [*report-counters* (atom initial-report-counters)]
    (test-vars vars)
    (let [summary (assoc (deref *report-counters*) :type :summary)]
      (report-summary summary)
      summary)))

;; run-tests with no args runs the current namespace; with namespace
;; symbols, runs those. Returns the {:test :pass :fail :error :type}
;; summary map, exactly clojure.test's shape.
(defn run-tests [& namespaces]
  (run-test-vars (clojure.core/-collect-test-vars namespaces)))

(defn run-all-tests []
  (run-test-vars (clojure.core/-all-test-vars)))

(defn successful? [summary]
  (and (= 0 (:fail summary)) (= 0 (:error summary))))

;; --- clojure.test completion (fundamentals audit 2026-07) ------------
;;
;; The remaining public surface of clojure.test, so a real test suite ports
;; without edits. Oracled against JVM Clojure 1.12.5 (`clojure` CLI,
;; 2026-07-21); frozen in conformance/tests/clojure-test-*.clj.

;; *initial-report-counters* is the DYNAMIC counterpart of the plain
;; initial-report-counters map above; a runner rebinds it to start a run
;; with different tallies. oracle: => {:test 0, :pass 0, :fail 0, :error 0}
(def ^:dynamic *initial-report-counters* initial-report-counters)

;; *load-tests* false makes deftest/with-test compile their bodies away, so
;; a production build carries no test code. oracle: default => true.
(def ^:dynamic *load-tests* true)

;; *stack-trace-depth* limits how many stack frames an :error report shows.
;; oracle: default => nil (unlimited). cljgo honors the var so code that
;; binds it still reads back what it set; our error reports print the
;; exception itself rather than a frame list, so the depth is not consulted.
(def ^:dynamic *stack-trace-depth* nil)

;; *test-out* is where test output goes; with-test-out binds *out* to it.
;; oracle: default => *out*, and (with-test-out (println "x")) writes to
;; whatever *test-out* names at that moment.
(def ^:dynamic *test-out* *out*)

(defmacro with-test-out
  "Runs body with *out* bound to the value of *test-out*."
  [& body]
  `(binding [*out* *test-out*] ~@body))

;; function? is clojure.test's own predicate (the `is` macro uses it to tell
;; a predicate CALL from an arbitrary expression) — public in clojure.test,
;; so it is public here too; -function? above is its long-standing private
;; twin and stays as the implementation. oracle: (function? '+) => true,
;; (function? 'let) => false (a macro), (function? 'no-such-sym) => nil,
;; (function? 5) => false.
(defn function?
  "Returns true if argument is a function or a symbol that resolves to
  a function (not a macro)."
  [x]
  (-function? x))

;; get-possibly-unbound-var: a var's value, or nil when it has no root
;; binding, instead of throwing. oracle: returns the fn for a bound var.
(defn get-possibly-unbound-var
  "Like var-get but returns nil if the var is unbound."
  [v]
  (try (deref v) (catch Throwable _e nil)))

;; file-position — a DOCUMENTED DEVIATION. On the JVM this reads frame n of
;; a fresh exception's stack trace and returns [file line]; cljgo has no
;; stack-frame introspection, so it returns nil rather than inventing a
;; position. Kept public because clojure.test exports it and porting code
;; may reference it; nothing in cljgo's own reporting depends on it.
(defn file-position
  "DEPRECATED on the JVM too. cljgo has no stack-frame introspection and
  returns nil; the JVM returns [file line] for stack frame n."
  [_n]
  nil)

(defmacro deftest-
  "Like deftest but the var is not public."
  [name & body]
  `(deftest ~(with-meta name (assoc (meta name) :private true)) ~@body))

(defmacro set-test
  "Sets :test metadata of the named var to a fn with the given body.
  The var must already exist."
  [name & body]
  `(alter-meta! (var ~name) assoc :test (fn [] ~@body)))

(defmacro with-test
  "Takes any definition form (that returns a Var) as the first argument.
  Remaining body goes in the :test metadata function for that Var."
  [definition & body]
  `(let [v# ~definition]
     (alter-meta! v# assoc :test (fn [] ~@body))
     v#))

;; test-all-vars: run every test var in ns with that namespace's fixtures.
;; (test-vars already groups by namespace and applies :once/:each, so this
;; is test-vars over the namespace's own test vars.)
;; -ns-sym accepts either shape the JVM's test-ns/test-all-vars do: a
;; namespace symbol, or a Namespace object (which prints as its own name in
;; cljgo and on the JVM alike, so str round-trips it).
(defn ^:private -ns-sym [ns]
  (if (symbol? ns) ns (symbol (str ns))))

(defn test-all-vars
  "Calls test-var on every var interned in the namespace that has a :test
  metadata entry."
  [ns]
  (test-vars (clojure.core/-collect-test-vars (list (-ns-sym ns)))))

(defn test-ns
  "Runs the tests in a namespace and returns the summary map. If the
  namespace has a fn named test-ns-hook, calls that instead."
  [ns]
  (binding [*report-counters* (atom *initial-report-counters*)]
    (test-all-vars (-ns-sym ns))
    (assoc (deref *report-counters*) :type :summary)))

(defn run-test-var
  "Runs the test for a single var and returns the summary map."
  [v]
  (run-test-vars (list v)))

(defmacro run-test
  "Runs a single test — (run-test test-name), the var is taken for you."
  [test-symbol]
  `(run-test-var (var ~test-symbol)))
